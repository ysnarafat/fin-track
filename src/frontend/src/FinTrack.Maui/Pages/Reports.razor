@page "/reports"

<PageTitle>Reports - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Reports</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        View financial reports and analytics here. This page will be implemented in future tasks.
    </MudText>
    
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Coming Soon</MudText>
        <MudText Typo="Typo.body2">
            Reporting features including:
        </MudText>
        <MudList T="string">
            <MudListItem T="string" Icon="Icons.Material.Filled.Assessment" Text="Financial dashboards" />
            <MudListItem T="string" Icon="Icons.Material.Filled.BarChart" Text="Spending analysis" />
            <MudListItem T="string" Icon="Icons.Material.Filled.DateRange" Text="Custom date ranges" />
            <MudListItem T="string" Icon="Icons.Material.Filled.FileDownload" Text="Export reports" />
        </MudList>
    </MudPaper>
</MudContainer>