@page "/transactions"

<PageTitle>Transactions - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Transactions</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Record and manage your financial transactions here. This page will be implemented in future tasks.
    </MudText>
    
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Coming Soon</MudText>
        <MudText Typo="Typo.body2">
            Transaction management features including:
        </MudText>
        <MudList T="string">
            <MudListItem T="string" Icon="Icons.Material.Filled.Receipt" Text="View all transactions" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Add" Text="Add new transactions" />
            <MudListItem T="string" Icon="Icons.Material.Filled.FilterList" Text="Filter and search transactions" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Category" Text="Categorize transactions" />
        </MudList>
    </MudPaper>
</MudContainer>