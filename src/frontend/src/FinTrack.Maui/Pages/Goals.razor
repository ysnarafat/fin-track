@page "/goals"

<PageTitle>Goals - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Financial Goals</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Set and track your financial goals here. This page will be implemented in future tasks.
    </MudText>
    
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Coming Soon</MudText>
        <MudText Typo="Typo.body2">
            Goal tracking features including:
        </MudText>
        <MudList T="string">
            <MudListItem T="string" Icon="Icons.Material.Filled.TrendingUp" Text="Set financial goals" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Timeline" Text="Track progress" />
            <MudListItem T="string" Icon="Icons.Material.Filled.EmojiEvents" Text="Celebrate milestones" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Insights" Text="Goal insights and recommendations" />
        </MudList>
    </MudPaper>
</MudContainer>