@page "/help"

<PageTitle>Help & Support - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Help & Support</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Get help and support for using FinTrack.
    </MudText>
    
    <MudGrid Class="mt-4">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="Icons.Material.Filled.QuestionAnswer" Class="mr-2" />
                    Frequently Asked Questions
                </MudText>
                <MudText Typo="Typo.body2">
                    Find answers to common questions about using FinTrack.
                </MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="Icons.Material.Filled.MenuBook" Class="mr-2" />
                    User Guide
                </MudText>
                <MudText Typo="Typo.body2">
                    Learn how to use all features of FinTrack effectively.
                </MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="Icons.Material.Filled.ContactSupport" Class="mr-2" />
                    Contact Support
                </MudText>
                <MudText Typo="Typo.body2">
                    Get in touch with our support team for assistance.
                </MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" GutterBottom="true">
                    <MudIcon Icon="Icons.Material.Filled.BugReport" Class="mr-2" />
                    Report a Bug
                </MudText>
                <MudText Typo="Typo.body2">
                    Report issues or bugs you encounter while using FinTrack.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>