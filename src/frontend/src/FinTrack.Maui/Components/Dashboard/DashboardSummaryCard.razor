@using FinTrack.Core.Entities

#nullable enable

<MudCard Elevation="2" Class="pa-4 h-100">
    <MudCardContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6" Color="@TitleColor">@Title</MudText>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@FormattedValue</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Subtitle</MudText>
            @if (ShowTrend && TrendValue.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@TrendIcon" Color="@TrendColor" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Color="@TrendColor">
                        @TrendText
                    </MudText>
                </MudStack>
            }
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public decimal Value { get; set; }
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public Color TitleColor { get; set; } = Color.Primary;
    [Parameter] public bool ShowTrend { get; set; } = false;
    [Parameter] public decimal? TrendValue { get; set; }
    [Parameter] public string Currency { get; set; } = "USD";

    private string FormattedValue => Title.Contains("Rate") ? $"{Value:F1}%" : Value.ToString("C");

    private string TrendIcon => TrendValue switch
    {
        > 0 => Icons.Material.Filled.TrendingUp,
        < 0 => Icons.Material.Filled.TrendingDown,
        _ => Icons.Material.Filled.TrendingFlat
    };

    private Color TrendColor => TrendValue switch
    {
        > 0 => Color.Success,
        < 0 => Color.Error,
        _ => Color.Default
    };

    private string TrendText => TrendValue switch
    {
        > 0 => $"+{TrendValue:P1} from last month",
        < 0 => $"{TrendValue:P1} from last month",
        _ => "No change from last month"
    };
}