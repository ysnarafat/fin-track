@using FinTrack.Core.Entities
@using FinTrack.Core.Enums
@inject ISnackbar Snackbar

<MudCard Elevation="2" Class="pa-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                @(IsEditMode ? "Edit Transaction" : "Add New Transaction")
            </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            @if (ShowCloseButton)
            {
                <MudIconButton Icon="Icons.Material.Filled.Close" 
                              Color="Color.Default" 
                              OnClick="OnCancel" />
            }
        </CardHeaderActions>
    </MudCardHeader>
    
    <MudCardContent>
        <EditForm Model="@Transaction" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            
            <MudGrid>
                <!-- Transaction Type -->
                <MudItem xs="12" sm="6">
                    <MudSelect T="TransactionType" 
                              @bind-Value="Transaction.Type" 
                              Label="Transaction Type" 
                              Variant="Variant.Outlined"
                              Required="true"
                              For="@(() => Transaction.Type)">
                        <MudSelectItem Value="TransactionType.Income">
                            <div class="d-flex align-center">
                                <MudIcon Icon="Icons.Material.Filled.TrendingUp" Color="Color.Success" Class="mr-2" />
                                Income
                            </div>
                        </MudSelectItem>
                        <MudSelectItem Value="TransactionType.Expense">
                            <div class="d-flex align-center">
                                <MudIcon Icon="Icons.Material.Filled.TrendingDown" Color="Color.Error" Class="mr-2" />
                                Expense
                            </div>
                        </MudSelectItem>
                        <MudSelectItem Value="TransactionType.Transfer">
                            <div class="d-flex align-center">
                                <MudIcon Icon="Icons.Material.Filled.SwapHoriz" Color="Color.Info" Class="mr-2" />
                                Transfer
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Amount -->
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" 
                                    @bind-Value="Transaction.Amount" 
                                    Label="Amount" 
                                    Variant="Variant.Outlined"
                                    Required="true"
                                    Min="0.01m"
                                    Step="0.01m"
                                    Format="C2"
                                    Culture="@System.Globalization.CultureInfo.CurrentCulture"
                                    For="@(() => Transaction.Amount)"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="Icons.Material.Filled.AttachMoney" />
                </MudItem>

                <!-- Description -->
                <MudItem xs="12">
                    <MudAutocomplete T="string" 
                                    @bind-Value="Transaction.Description"
                                    SearchFunc="@SearchDescriptions"
                                    Label="Description" 
                                    Variant="Variant.Outlined"
                                    Required="true"
                                    MaxLength="500"
                                    For="@(() => Transaction.Description)"
                                    HelperText="Brief description of the transaction"
                                    Placeholder="Enter transaction description..."
                                    ShowProgressIndicator="@IsSearchingDescriptions"
                                    MaxItems="10"
                                    Clearable="true"
                                    ResetValueOnEmptyText="false"
                                    CoerceText="true"
                                    CoerceValue="false">
                        <ItemTemplate Context="description">
                            <div class="d-flex align-center">
                                <MudIcon Icon="Icons.Material.Filled.History" Class="mr-2" Size="Size.Small" />
                                <MudText Typo="Typo.body2">@description</MudText>
                            </div>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>

                <!-- Date -->
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="TransactionDate" 
                                  Label="Transaction Date" 
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxDate="DateTime.Today.AddDays(1)"
                                  For="@(() => Transaction.Date)" />
                </MudItem>

                <!-- Account Selection -->
                <MudItem xs="12" sm="6">
                    <MudSelect T="int" 
                              @bind-Value="Transaction.AccountId" 
                              Label="Account" 
                              Variant="Variant.Outlined"
                              Required="true"
                              For="@(() => Transaction.AccountId)">
                        @if (Accounts != null)
                        {
                            @foreach (var account in Accounts)
                            {
                                <MudSelectItem Value="@account.Id">
                                    <div class="d-flex align-center justify-space-between">
                                        <span>@account.Name</span>
                                        <MudChip T="string" Size="Size.Small" Color="GetAccountTypeColor(account.Type)">
                                            @account.Type
                                        </MudChip>
                                    </div>
                                </MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>

                <!-- Category Selection -->
                <MudItem xs="12" sm="@(Transaction.Type == TransactionType.Transfer ? 6 : 12)">
                    <CategorySelector @bind-SelectedCategoryId="Transaction.CategoryId" 
                                    Categories="Categories" 
                                    Required="true" />
                </MudItem>

                <!-- Transfer To Account (only for transfers) -->
                @if (Transaction.Type == TransactionType.Transfer)
                {
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?" 
                                  @bind-Value="Transaction.TransferToAccountId" 
                                  Label="Transfer To Account" 
                                  Variant="Variant.Outlined"
                                  Required="true">
                            @if (Accounts != null)
                            {
                                @foreach (var account in Accounts.Where(a => a.Id != Transaction.AccountId))
                                {
                                    <MudSelectItem Value="@((int?)account.Id)">
                                        <div class="d-flex align-center justify-space-between">
                                            <span>@account.Name</span>
                                            <MudChip T="string" Size="Size.Small" Color="GetAccountTypeColor(account.Type)">
                                                @account.Type
                                            </MudChip>
                                        </div>
                                    </MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                }

                <!-- Reference Number -->
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Transaction.ReferenceNumber" 
                                 Label="Reference Number" 
                                 Variant="Variant.Outlined"
                                 MaxLength="50"
                                 HelperText="Check number, confirmation code, etc." />
                </MudItem>

                <!-- Notes -->
                <MudItem xs="12">
                    <MudTextField @bind-Value="Transaction.Notes" 
                                 Label="Notes" 
                                 Variant="Variant.Outlined"
                                 Lines="3"
                                 MaxLength="1000"
                                 Counter="1000"
                                 HelperText="Additional details or notes" />
                </MudItem>
            </MudGrid>

            <ValidationSummary />
        </EditForm>
    </MudCardContent>
    
    <MudCardActions Class="d-flex justify-end gap-2">
        @if (ShowCancelButton)
        {
            <MudButton Variant="Variant.Text" 
                      Color="Color.Default" 
                      OnClick="OnCancel"
                      StartIcon="Icons.Material.Filled.Cancel">
                Cancel
            </MudButton>
        }
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  ButtonType="ButtonType.Submit"
                  StartIcon="Icons.Material.Filled.Save"
                  Disabled="@IsSubmitting">
            @if (IsSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                <span class="ml-2">Saving...</span>
            }
            else
            {
                <span>@(IsEditMode ? "Update" : "Save") Transaction</span>
            }
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter] public Transaction Transaction { get; set; } = new();
    [Parameter] public List<Account>? Accounts { get; set; }
    [Parameter] public List<Category>? Categories { get; set; }
    [Parameter] public List<Transaction>? RecentTransactions { get; set; }
    [Parameter] public bool IsEditMode { get; set; } = false;
    [Parameter] public bool ShowCloseButton { get; set; } = false;
    [Parameter] public bool ShowCancelButton { get; set; } = true;
    [Parameter] public EventCallback<Transaction> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsSubmitting = false;
    private bool IsSearchingDescriptions = false;
    
    private DateTime? TransactionDate
    {
        get => Transaction.Date == default ? DateTime.Today : Transaction.Date;
        set => Transaction.Date = value ?? DateTime.Today;
    }

    protected override void OnInitialized()
    {
        if (Transaction.Date == default)
        {
            Transaction.Date = DateTime.Today;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (IsSubmitting) return;

        try
        {
            IsSubmitting = true;
            
            // Validate transaction
            if (!Transaction.IsValid())
            {
                Snackbar.Add("Please check all required fields", Severity.Warning);
                return;
            }

            await OnSubmit.InvokeAsync(Transaction);
            
            if (!IsEditMode)
            {
                // Reset form for new transaction
                Transaction = new Transaction { Date = DateTime.Today };
                StateHasChanged();
            }
            
            Snackbar.Add($"Transaction {(IsEditMode ? "updated" : "saved")} successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving transaction: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task<IEnumerable<string>> SearchDescriptions(string value, CancellationToken cancellationToken)
    {
        IsSearchingDescriptions = true;
        await Task.Delay(100, cancellationToken); // Simulate search delay
        IsSearchingDescriptions = false;

        if (string.IsNullOrWhiteSpace(value))
        {
            // Return recent descriptions from the same category if available
            return GetRecentDescriptions().Take(5);
        }

        // Search through recent descriptions
        var recentDescriptions = GetRecentDescriptions();
        return recentDescriptions
            .Where(d => d.Contains(value, StringComparison.OrdinalIgnoreCase))
            .OrderBy(d => d.StartsWith(value, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ThenBy(d => d)
            .Take(10);
    }

    private IEnumerable<string> GetRecentDescriptions()
    {
        var descriptions = new List<string>();
        
        // Add recent transaction descriptions if available
        if (RecentTransactions != null)
        {
            descriptions.AddRange(RecentTransactions
                .Where(t => !string.IsNullOrWhiteSpace(t.Description))
                .Select(t => t.Description)
                .Distinct()
                .OrderByDescending(d => RecentTransactions.Count(t => t.Description == d))
                .Take(15));
        }
        
        // Add common transaction descriptions as fallback
        var commonDescriptions = new List<string>
        {
            "Grocery shopping", "Gas station", "Restaurant", "Coffee shop", "Online purchase",
            "Utility bill", "Phone bill", "Internet bill", "Rent payment", "Salary deposit",
            "ATM withdrawal", "Bank transfer", "Insurance payment", "Medical expense", "Pharmacy",
            "Subscription service", "Entertainment", "Transportation", "Parking fee", "Taxi ride"
        };
        
        // Merge and deduplicate
        descriptions.AddRange(commonDescriptions.Where(cd => !descriptions.Contains(cd)));
        
        return descriptions.Take(20);
    }

    private Color GetAccountTypeColor(AccountType accountType)
    {
        return accountType switch
        {
            AccountType.Checking => Color.Primary,
            AccountType.Savings => Color.Success,
            AccountType.CreditCard => Color.Warning,
            AccountType.Investment => Color.Info,
            _ => Color.Default
        };
    }
}