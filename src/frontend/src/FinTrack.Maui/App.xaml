<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FinTrack.Maui"
             xmlns:services="clr-namespace:FinTrack.Maui.Services"
             xmlns:converters="clr-namespace:FinTrack.Maui.Converters"
             x:Class="FinTrack.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <!-- Converters -->
                    <services:CurrencyConverter x:Key="CurrencyConverter" />
                    <services:PercentageConverter x:Key="PercentageConverter" />
                    <services:PercentageToDecimalConverter x:Key="PercentageToDecimalConverter" />
                    <services:AmountToColorConverter x:Key="AmountToColorConverter" />
                    <services:IsNotNullConverter x:Key="IsNotNullConverter" />
                    <services:InvertedBoolConverter x:Key="InvertedBoolConverter" />
                    <converters:InvertedBoolConverter x:Key="InvertedBoolConverter2" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="PageBackgroundColor">#512bdf</Color>
            <Color x:Key="PrimaryTextColor">White</Color>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="TextColor" Value="{DynamicResource PrimaryTextColor}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="BackgroundColor" Value="#2b0b98" />
                <Setter Property="Padding" Value="14,10" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>