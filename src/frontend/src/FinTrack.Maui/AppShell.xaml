<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FinTrack.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FinTrack.Maui.Views"
    xmlns:viewmodels="clr-namespace:FinTrack.Maui.ViewModels"
    Title="FinTrack">
    <Shell.FlyoutBackgroundColor>#1E1E1E</Shell.FlyoutBackgroundColor>
    <Shell.TitleColor>White</Shell.TitleColor>
    
    <!-- Sync Status Header -->
    <Shell.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Label Grid.Column="0" 
                   Text="FinTrack" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="White" 
                   VerticalOptions="Center" />
            
            <StackLayout Grid.Column="1" 
                         Orientation="Horizontal" 
                         Spacing="8" 
                         VerticalOptions="Center">
                
                <!-- Sync Status Indicator -->
                <Border BackgroundColor="Transparent" 
                       Padding="8,4"
                       x:Name="SyncStatusFrame"
                       IsVisible="{Binding AreSyncIndicatorsEnabled}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSyncStatusTapped" />
                    </Border.GestureRecognizers>
                    
                    <StackLayout Orientation="Horizontal" Spacing="4">
                        <Label x:Name="SyncStatusIcon"
                               Text="●" 
                               FontSize="12" 
                               TextColor="{Binding StatusColor}"
                               VerticalOptions="Center" />
                        
                        <Label x:Name="SyncStatusText"
                               Text="{Binding StatusText}" 
                               FontSize="12" 
                               TextColor="White" 
                               VerticalOptions="Center" />
                        
                        <!-- Pending changes indicator -->
                        <Border x:Name="PendingChangesIndicator"
                               BackgroundColor="Orange"
                               WidthRequest="16"
                               HeightRequest="16"
                               Padding="0"
                               IsVisible="{Binding HasPendingChanges}">
                            <Label Text="{Binding PendingChangesCount}"
                                   FontSize="10"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                    </StackLayout>
                </Border>
            </StackLayout>
        </Grid>
    </Shell.TitleView>
    <TabBar>
        <!-- Dashboard Tab -->
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="dashboard"
            Icon="dotnet_bot.svg" />
        <!-- Transactions Tab -->
        <ShellContent
            Title="Transactions"
            ContentTemplate="{DataTemplate views:TransactionsPage}"
            Route="transactions"
            Icon="dotnet_bot.svg" />
        <!-- Accounts Tab -->
        <ShellContent
            Title="Accounts"
            ContentTemplate="{DataTemplate views:AccountsPage}"
            Route="accounts"
            Icon="dotnet_bot.svg" />
        <!-- Budgets Tab -->
        <ShellContent
            Title="Budgets"
            ContentTemplate="{DataTemplate views:BudgetsPage}"
            Route="budgets"
            Icon="dotnet_bot.svg" />
        <!-- Goals Tab -->
        <ShellContent
            Title="Goals"
            ContentTemplate="{DataTemplate views:GoalsPage}"
            Route="goals"
            Icon="financial_goal.svg" />
        <!-- Reports Tab -->
        <ShellContent
            Title="Reports"
            ContentTemplate="{DataTemplate views:ReportsPage}"
            Route="reports"
            Icon="dotnet_bot.svg" />
    </TabBar>
    
    <!-- Additional routes for navigation -->
    <ShellContent
        Route="transactions/add"
        ContentTemplate="{DataTemplate views:TransactionFormPage}"
        Shell.PresentationMode="Modal" />
    
    <ShellContent
        Route="budgets/add"
        ContentTemplate="{DataTemplate views:BudgetFormPage}"
        Shell.PresentationMode="Modal" />
    
    <ShellContent
        Route="budgets/edit"
        ContentTemplate="{DataTemplate views:BudgetFormPage}"
        Shell.PresentationMode="Modal" />
    
    <ShellContent
        Route="goals/add"
        ContentTemplate="{DataTemplate views:GoalFormPage}"
        Shell.PresentationMode="Modal" />
    
    <ShellContent
        Route="goals/edit"
        ContentTemplate="{DataTemplate views:GoalFormPage}"
        Shell.PresentationMode="Modal" />
</Shell>