<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="FinTrack.Maui.Views.BudgetsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FinTrack.Maui.Models"
             xmlns:services="clr-namespace:FinTrack.Maui.Services"
             Title="Budgets"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <services:CurrencyConverter x:Key="CurrencyConverter" />
            <services:PercentageConverter x:Key="PercentageConverter" />

            <!-- Styles -->
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#1E1E1E" />
                <Setter Property="Stroke" Value="#333333" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="16,8,16,8" />
            </Style>

            <Style x:Key="SummaryCardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#1E1E1E" />
                <Setter Property="Stroke" Value="#333333" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="4,4,4,4" />
            </Style>

            <Style x:Key="AlertBorderStyle" TargetType="Border">
                <Setter Property="Stroke" Value="#F97316" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="BackgroundColor" Value="#1E1E1E" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="16,4,16,4" />
            </Style>

            <Style x:Key="TitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="SubtitleLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="#B0B0B0" />
            </Style>

            <Style x:Key="AmountLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}"
                 RefreshColor="White">

        <ScrollView>
            <StackLayout Spacing="8">

                <!-- Loading Indicator -->
                <ActivityIndicator IsVisible="{Binding IsLoading}"
                                   IsRunning="{Binding IsLoading}"
                                   Color="White"
                                   Margin="0,20" />

                <!-- Budget Summary -->
                <Border Style="{StaticResource CardBorderStyle}"
                        IsVisible="{Binding BudgetSummary, Converter={StaticResource IsNotNullConverter}}">
                    <StackLayout Spacing="12">
                        <Label Text="Budget Overview"
                               Style="{StaticResource TitleLabelStyle}" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <!-- Total Budgeted -->
                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                                <StackLayout Spacing="4">
                                    <Label Text="Budgeted" Style="{StaticResource SubtitleLabelStyle}" />
                                    <Label Text="{Binding BudgetSummary.TotalBudgeted, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource AmountLabelStyle}" />
                                </StackLayout>
                            </Border>

                            <!-- Total Spent -->
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                                <StackLayout Spacing="4">
                                    <Label Text="Spent" Style="{StaticResource SubtitleLabelStyle}" />
                                    <Label Text="{Binding BudgetSummary.TotalSpent, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource AmountLabelStyle}" />
                                </StackLayout>
                            </Border>

                            <!-- Remaining -->
                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                                <StackLayout Spacing="4">
                                    <Label Text="Remaining" Style="{StaticResource SubtitleLabelStyle}" />
                                    <Label Text="{Binding BudgetSummary.TotalRemaining, Converter={StaticResource CurrencyConverter}}"
                                           Style="{StaticResource AmountLabelStyle}" />
                                </StackLayout>
                            </Border>

                            <!-- Overall Progress -->
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                                <StackLayout Spacing="4">
                                    <Label Text="Progress" Style="{StaticResource SubtitleLabelStyle}" />
                                    <Label Text="{Binding BudgetSummary.OverallUtilization, Converter={StaticResource PercentageConverter}}"
                                           Style="{StaticResource AmountLabelStyle}" />
                                </StackLayout>
                            </Border>
                        </Grid>
                    </StackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}"
         IsVisible="{Binding BudgetSummary, Converter={StaticResource IsNotNullConverter}}">
                    <!-- Budget Alerts -->
                    <StackLayout Spacing="12">
                        <Label Text="Budget Alerts"
                           Style="{StaticResource TitleLabelStyle}"
                               />

                        <CollectionView ItemsSource="{Binding BudgetAlerts}" IsVisible="{Binding HasAlerts}" >
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="services:BudgetAlert">
                                    <Border Style="{StaticResource AlertBorderStyle}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding CategoryName}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                                <Label Text="{Binding Message}"
                                                   FontSize="12"
                                                   TextColor="#B0B0B0" />
                                            </StackLayout>

                                            <Button Grid.Column="1"
                                                Text="✕"
                                                FontSize="12"
                                                BackgroundColor="Transparent"
                                                TextColor="#B0B0B0"
                                                WidthRequest="30"
                                                HeightRequest="30"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DismissAlertCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Shown when the collection is empty -->
                        <Label IsVisible="{Binding HasAlerts, Converter={services:InvertedBoolConverter}}"
                                   Text="No budget alerts"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Fill"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   FontSize="14"
                                   TextColor="#B0B0B0" />
                    </StackLayout>
                </Border>

                <!-- Budget List Header -->
                <Grid Margin="16,8,16,8" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="Your Budgets"
                           Style="{StaticResource TitleLabelStyle}" />

                    <Button Grid.Column="1"
                            Text="+ Add Budget"
                            BackgroundColor="#3B82F6"
                            TextColor="White"
                            FontSize="14"
                            CornerRadius="6"
                            Padding="12,8"
                            Command="{Binding AddBudgetCommand}" />
                </Grid>

                <!-- Empty State -->
                <StackLayout IsVisible="{Binding HasBudgets, Converter={StaticResource InvertedBoolConverter}}"
                             Spacing="16"
                             Margin="32"
                             VerticalOptions="CenterAndExpand">
                    <Label Text="💰"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="No budgets yet"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Create your first budget to start tracking your spending"
                           FontSize="14"
                           TextColor="#B0B0B0"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Create Budget"
                            BackgroundColor="#3B82F6"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="16,12"
                            HorizontalOptions="Center"
                            Command="{Binding AddBudgetCommand}" />
                </StackLayout>

                <Border Style="{StaticResource CardBorderStyle}">
                    <!-- Budget Cards -->
                    <CollectionView ItemsSource="{Binding Budgets}"
                                IsVisible="{Binding HasBudgets}"
                                ItemSizingStrategy="MeasureAllItems">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BudgetModel">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditBudgetCommand}"
                                                          CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="8" ColumnSpacing="12">

                                        <!-- Category Color Indicator -->
                                        <BoxView Grid.Row="0" Grid.RowSpan="4" Grid.Column="0"
                                             Color="{Binding CategoryColor}"
                                             WidthRequest="4"
                                             CornerRadius="2" />

                                        <!-- Budget Info -->
                                        <StackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding CategoryName}"
                                               Style="{StaticResource TitleLabelStyle}" />
                                            <Label Text="{Binding Name}"
                                               Style="{StaticResource SubtitleLabelStyle}" />
                                        </StackLayout>

                                        <!-- Status Badge -->
                                        <Border Grid.Row="0" Grid.Column="2"
                                            BackgroundColor="{Binding StatusColor}"
                                            Padding="8,4"
                                            StrokeShape="RoundRectangle 12"
                                            Stroke="Transparent">
                                            <Label Text="{Binding StatusText}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                        </Border>

                                        <!-- Progress Bar -->
                                        <StackLayout Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Spacing="4">
                                            <ProgressBar Progress="{Binding UtilizationPercentage, Converter={StaticResource PercentageToDecimalConverter}}"
                                                     ProgressColor="{Binding StatusColor}"
                                                     BackgroundColor="#333333"
                                                     HeightRequest="8" />
                                            <Label Text="{Binding UtilizationPercentage, StringFormat='{0:F0}% used'}"
                                               FontSize="12"
                                               TextColor="#B0B0B0" />
                                        </StackLayout>

                                        <!-- Amount Info -->
                                        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                          ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                            <StackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="Spent" Style="{StaticResource SubtitleLabelStyle}" />
                                                <Label Text="{Binding CurrentSpending, Converter={StaticResource CurrencyConverter}}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                            </StackLayout>

                                            <StackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="Budget" Style="{StaticResource SubtitleLabelStyle}" />
                                                <Label Text="{Binding BudgetLimit, Converter={StaticResource CurrencyConverter}}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                            </StackLayout>

                                            <StackLayout Grid.Column="2" Spacing="2">
                                                <Label Text="Remaining" Style="{StaticResource SubtitleLabelStyle}" />
                                                <Label Text="{Binding RemainingAmount, Converter={StaticResource CurrencyConverter}}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding RemainingAmount, Converter={StaticResource AmountToColorConverter}}" />
                                            </StackLayout>
                                        </Grid>

                                        <!-- Action Buttons -->
                                        <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                          ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                               Text="{Binding StartDate, StringFormat='Valid until {0:MMM dd}'}"
                                               FontSize="12"
                                               TextColor="#B0B0B0"
                                               VerticalOptions="Center" />

                                            <Button Grid.Column="1"
                                                Text="Delete"
                                                BackgroundColor="#EF4444"
                                                TextColor="White"
                                                FontSize="12"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteBudgetCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
                <!-- Bottom Spacing -->
                <BoxView HeightRequest="16" Color="Transparent" />

            </StackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>