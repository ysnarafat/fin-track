@page "/"

<PageTitle>Dashboard - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Welcome to FinTrack! Your financial overview will appear here.
    </MudText>
    
    <MudGrid>
        <!-- Summary Cards -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Color="Color.Primary">Total Balance</MudText>
                <MudText Typo="Typo.h4">$0.00</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Across all accounts</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Color="Color.Success">Monthly Income</MudText>
                <MudText Typo="Typo.h4">$0.00</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">This month</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Color="Color.Error">Monthly Expenses</MudText>
                <MudText Typo="Typo.h4">$0.00</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">This month</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Color="Color.Info">Savings Rate</MudText>
                <MudText Typo="Typo.h4">0%</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">This month</MudText>
            </MudPaper>
        </MudItem>
        
        <!-- Recent Transactions -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" GutterBottom="true">Recent Transactions</MudText>
                <MudList T="string">
                    <MudListItem T="string">
                        <MudText Typo="Typo.body1">No transactions yet</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Start by adding your first transaction</MudText>
                    </MudListItem>
                </MudList>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           StartIcon="Icons.Material.Filled.Add"
                           Href="/transactions">
                    Add Transaction
                </MudButton>
            </MudPaper>
        </MudItem>
        
        <!-- Quick Actions -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" GutterBottom="true">Quick Actions</MudText>
                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Primary" 
                               StartIcon="Icons.Material.Filled.AccountBalance"
                               FullWidth="true"
                               Href="/accounts">
                        Add Account
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Secondary" 
                               StartIcon="Icons.Material.Filled.Receipt"
                               FullWidth="true"
                               Href="/transactions">
                        Record Transaction
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Tertiary" 
                               StartIcon="Icons.Material.Filled.PieChart"
                               FullWidth="true"
                               Href="/budgets">
                        Create Budget
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Success" 
                               StartIcon="Icons.Material.Filled.TrendingUp"
                               FullWidth="true"
                               Href="/goals">
                        Set Goal
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <!-- Getting Started -->
        <MudItem xs="12">
            <MudAlert Severity="Severity.Info" Class="mt-4">
                <MudText Typo="Typo.body1">
                    <strong>Welcome to FinTrack!</strong> This is your financial dashboard. 
                    Start by adding your accounts and recording transactions to see your financial overview.
                </MudText>
            </MudAlert>
        </MudItem>
    </MudGrid>
</MudContainer>
