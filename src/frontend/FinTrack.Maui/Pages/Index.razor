@page "/"
@using FinTrack.Maui.Models
@using FinTrack.Maui.Components.Dashboard
@using FinTrack.Core.Entities
@using FinTrack.Core.Enums

#nullable enable

<PageTitle>Dashboard - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
    <MudStack Spacing="4">
        <!-- Header -->
        <div>
            <MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Welcome to FinTrack! Here's your financial overview.
            </MudText>
        </div>
        
        <!-- Summary Cards -->
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <DashboardSummaryCard Title="Total Balance"
                                    Value="@dashboardData.TotalBalance"
                                    Subtitle="Across all accounts"
                                    TitleColor="Color.Primary"
                                    ShowTrend="true"
                                    TrendValue="@dashboardData.Trends.BalanceTrend" />
            </MudItem>
            
            <MudItem xs="12" sm="6" md="3">
                <DashboardSummaryCard Title="Monthly Income"
                                    Value="@dashboardData.MonthlyIncome"
                                    Subtitle="This month"
                                    TitleColor="Color.Success"
                                    ShowTrend="true"
                                    TrendValue="@dashboardData.Trends.IncomeTrend" />
            </MudItem>
            
            <MudItem xs="12" sm="6" md="3">
                <DashboardSummaryCard Title="Monthly Expenses"
                                    Value="@dashboardData.MonthlyExpenses"
                                    Subtitle="This month"
                                    TitleColor="Color.Error"
                                    ShowTrend="true"
                                    TrendValue="@dashboardData.Trends.ExpenseTrend" />
            </MudItem>
            
            <MudItem xs="12" sm="6" md="3">
                <DashboardSummaryCard Title="Savings Rate"
                                    Value="@(dashboardData.SavingsRate * 100)"
                                    Subtitle="This month"
                                    TitleColor="Color.Info"
                                    ShowTrend="true"
                                    TrendValue="@dashboardData.Trends.SavingsRateTrend" />
            </MudItem>
        </MudGrid>
        
        <!-- Main Content -->
        <MudGrid>
            <!-- Recent Transactions -->
            <MudItem xs="12" md="8">
                <RecentTransactionsWidget Transactions="@dashboardData.RecentTransactions" 
                                        MaxItems="5" />
            </MudItem>
            
            <!-- Quick Actions -->
            <MudItem xs="12" md="4">
                <QuickActionsPanel />
            </MudItem>
        </MudGrid>
        
        <!-- Getting Started Alert (only show when no data) -->
        @if (dashboardData.AccountCount == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-2">
                <MudText Typo="Typo.body1">
                    <strong>Welcome to FinTrack!</strong> This is your financial dashboard. 
                    Start by adding your accounts and recording transactions to see your financial overview.
                </MudText>
            </MudAlert>
        }
    </MudStack>
</MudContainer>

@code {
    private DashboardData dashboardData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardDataAsync();
    }

    private Task LoadDashboardDataAsync()
    {
        // TODO: Replace with actual data service calls
        // For now, using mock data to demonstrate the UI components
        
        dashboardData = new DashboardData
        {
            TotalBalance = 5247.83m,
            MonthlyIncome = 4500.00m,
            MonthlyExpenses = 3200.45m,
            AccountCount = 3,
            RecentTransactions = GetMockTransactions(),
            Trends = new DashboardTrends
            {
                BalanceTrend = 0.08m, // 8% increase
                IncomeTrend = 0.05m,  // 5% increase
                ExpenseTrend = -0.02m, // 2% decrease
                SavingsRateTrend = 0.12m // 12% increase
            }
        };
        
        StateHasChanged();
        return Task.CompletedTask;
    }

