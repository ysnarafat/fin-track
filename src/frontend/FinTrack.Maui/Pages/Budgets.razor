@page "/budgets"

<PageTitle>Budgets - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Budgets</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Create and monitor your budgets here. This page will be implemented in future tasks.
    </MudText>
    
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Coming Soon</MudText>
        <MudText Typo="Typo.body2">
            Budget management features including:
        </MudText>
        <MudList T="string">
            <MudListItem T="string" Icon="Icons.Material.Filled.PieChart" Text="View budget overview" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Add" Text="Create new budgets" />
            <MudListItem T="string" Icon="Icons.Material.Filled.TrendingUp" Text="Track budget progress" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Notifications" Text="Budget alerts and notifications" />
        </MudList>
    </MudPaper>
</MudContainer>