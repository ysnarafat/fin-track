@page "/accounts"

<PageTitle>Accounts - FinTrack</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudText Typo="Typo.h4" GutterBottom="true">Accounts</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Manage your financial accounts here. This page will be implemented in future tasks.
    </MudText>
    
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" GutterBottom="true">Coming Soon</MudText>
        <MudText Typo="Typo.body2">
            Account management features including:
        </MudText>
        <MudList T="string">
            <MudListItem T="string" Icon="Icons.Material.Filled.AccountBalance" Text="View all accounts" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Add" Text="Add new accounts" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Edit" Text="Edit account details" />
            <MudListItem T="string" Icon="Icons.Material.Filled.Visibility" Text="View account history" />
        </MudList>
    </MudPaper>
</MudContainer>